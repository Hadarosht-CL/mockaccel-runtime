# EditorConfig - https://editorconfig.org
# Tells every editor that supports it to use the same baseline formatting,
# regardless of the user's personal settings.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{cpp,hpp,h,c,py,cmake}]
indent_size = 4

[CMakeLists.txt]
indent_size = 4

[*.{yml,yaml,json}]
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
# Markdown is sensitive to trailing spaces (they create line breaks).
trim_trailing_whitespace = false
